# Admin login (used by the /admin area). Change these.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Secret used to sign the admin session cookie. Use a long random string, e.g.
#   openssl rand -base64 32
SESSION_SECRET=replace-with-a-long-random-secret

# --- Catalog store: Upstash Redis (Vercel KV) ---
# Add an Upstash Redis store from the Vercel Marketplace and connect it to the
# project; it injects these automatically. For local dev, `vercel env pull`.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# (UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN are also accepted.)

# --- Audio playback: direct Google Drive API (REQUIRED) ---
# A referrer-restricted, Drive-API-only browser key. Audio streams DIRECTLY from
# Google (no Vercel function/bandwidth). Public by design (like a Maps key) - it
# must be HTTP-referrer restricted to your domain in the Cloud Console. There is
# no proxy fallback: without this, playback will not work.
NEXT_PUBLIC_DRIVE_API_KEY=

# --- Cover images: Vercel Blob ---
# On Vercel, connecting a (public) Blob store provisions BLOB_STORE_ID (+ a
# webhook key) and the SDK authenticates with the auto-injected VERCEL_OIDC_TOKEN.
# For local dev, `vercel env pull` or create a Read/Write token below.
# BLOB_READ_WRITE_TOKEN=
